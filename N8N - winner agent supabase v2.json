    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst output = String(input.output || '').trim();\n\nfunction safeJsonParse(s) {\n  const cleaned = s.replace(/```json/gi, '').replace(/```/g, '').trim();\n  try { return JSON.parse(cleaned); } catch { return null; }\n}\n\nconst parsed = safeJsonParse(output) || {};\n\nreturn [{\n  json: {\n    ...input,\n    focus_keyword: parsed.focus_keyword || input.topic,\n    keywords: Array.isArray(parsed.keywords) ? parsed.keywords : [],\n    search_intent: parsed.search_intent || 'informational',\n    article_type: parsed.article_type || 'general',\n  }\n}];"
