        "text": "={{\"Focus Keyword: \" + $json.focus_keyword + \"\\nRelated Keywords: \" + ($json.keywords || []).join(\", \") + \"\\nArticle Type: \" + $json.article_type + \"\\nTopic: \" + $json.topic}}",
        "options": {
          "systemMessage": "Kamu adalah SEO Content Writer profesional. Tulis artikel SEO berkualitas tinggi.\n\nFormat output WAJIB:\nJUDUL: [judul SEO-friendly maks 60 karakter, mengandung focus keyword]\nSLUG: [slug URL maks 5 kata, huruf kecil, pisah strip]\nMETA: [meta description 150-160 karakter mengandung focus keyword]\nKONTEN: [artikel HTML lengkap dengan h2,h3,p,ul,li - keyword density 1-2% - min 1 external link rel noopener - min 1 internal link placeholder - minimal 800 kata]\nTAGS: [tag1, tag2, tag3, tag4, tag5]"
        }
      },
      "id": "ab6b5c6e-01f8-4c3b-aea7-0b08bb5a9cc7",
      "name": "Content Writer (Agent)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [1008, -160]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst raw = String(input.output || '').replace(/```/g, '').trim();\n\nfunction pick(prefix) {\n  const re = new RegExp(`^${prefix}:\\\\s*`, 'i');\n  const line = raw.split(/\\r?\\n/).find(l => re.test(l));\n  if (line) return line.replace(re, '').trim();\n  return '';\n}\n\nfunction pickBlock(prefix) {\n  const re = new RegExp(`^${prefix}:\\\\s*`, 'i');\n  const lines = raw.split(/\\r?\\n/);\n  const start = lines.findIndex(l => re.test(l));\n  if (start === -1) return '';\n  const collected = [];\n  for (let i = start; i < lines.length; i++) {\n    const l = lines[i];\n    if (i === start) collected.push(l.replace(re, ''));\n    else {\n      if (/^(JUDUL|SLUG|META|KONTEN|TAGS):\\s*/i.test(l)) break;\n      collected.push(l);\n    }\n  }\n  return collected.join('\\n').trim();\n}\n\nconst title = pick('JUDUL');\nconst slug = pick('SLUG');\nconst meta = pick('META');\nconst content = pickBlock('KONTEN');\nconst tagsRaw = pick('TAGS');\nconst tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];\n\nreturn [{\n  json: {\n    ...input,\n    article_title: title,\n    article_slug: slug,\n    article_meta: meta,\n    article_content: content,\n    article_tags: tags,\n  }\n}];"
      },
      "id": "2f2c0b6e-1c90-4f3f-a5ed-34bb9df050e7",
